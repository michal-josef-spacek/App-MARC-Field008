#!/usr/bin/env perl

use strict;
use warnings;

use App::MARC::Field008;

our $VERSION = 0.01;

# Run.
exit App::MARC::Field008->new->run;

# Print version.
sub VERSION_MESSAGE {
	print $VERSION."\n";
	exit 0;
}

__END__

=pod

=encoding utf8

=head1 NAME

marc-field008 - Script to decode MARC 008 field from file or string.

=head1 SYNOPSIS

 marc-field008 [-a] [-d] [-f marc_xml_file] [-h] [-v] [--version] [field008_string]

=head1 DESCRIPTION

It supports MARC XML files now.

=head1 ARGUMENTS

=over 8

=item * C<-a>

Print with ANSI colors.
Or use C<NO_COLOR>/C<COLOR> env variables.

=item * C<-d>

Don't print description.

=item * C<-f marc_xml_file>

MARC XML file name to decode of leader

=item * C<-h>

Print help.

=item * C<-v>

Verbose mode.

=item * C<--version>

Print version of script.

=item * C<field008_string>

MARC 008 field string to decode.

=back

=head1 EXAMPLE

 marc-field008 -f __MARC.xml__

